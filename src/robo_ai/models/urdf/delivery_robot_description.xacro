<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="delivery_robot">

  <xacro:include filename="$(find robo_ai)/gazebo/delivery_robot.gazebo" />

  <link name="body">
    <inertial>
      <origin xyz="0 0 0.201" rpy="0 0 0"/>
      <mass value="70"/>
      <inertia ixx="5.1526" iyy="2.4944" izz="6.2829" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.5708"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/body.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 -1.5708"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/body.obj" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="tire_left">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.757897446874" iyy="1.302975553365" izz="0.757897446874" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.5708"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/WheelSide.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06137"/>
      </geometry>
    </collision>
  </link>

  <link name="tire_right">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.757897446874" iyy="1.302975553365" izz="0.757897446874" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.5708"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/WheelSide.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06137"/>
      </geometry>
    </collision>
  </link>

  <link name="caster_fl">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/WheelMain.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
  </link>

  <link name="caster_bl">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/WheelMain.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
  </link>

  <link name="caster_fr">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/WheelMain.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
  </link>

  <link name="caster_br">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/WheelMain.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_tire_left" type="continuous">
    <origin xyz="0 0.26 0.10" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="tire_left"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="joint_tire_right" type="continuous">
    <origin xyz="0 -0.26 0.10" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="tire_right"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="caster_fl_joint" type="fixed">
    <origin xyz="-0.220 -0.262 0.061" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="caster_fl"/>
  </joint>

  <joint name="caster_bl_joint" type="fixed">
    <origin xyz="-0.220 0.334 0.061" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="caster_bl"/>
  </joint>

  <joint name="caster_fr_joint" type="fixed">
    <origin xyz="0.217 -0.262 0.061" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="caster_fr"/>
  </joint>

  <joint name="caster_br_joint" type="fixed">
    <origin xyz="0.217 0.334 0.061" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="caster_br"/>
  </joint>

  <!-- =================== SENSORS =================== -->

  <link name="lidar">
    <inertial>
      <origin xyz="0 0 0.004" rpy="0 0 0"/>
      <mass value="0.026"/>
      <inertia ixx="0.000006" iyy="0.000006" izz="0.000012" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/lidar.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/lidar.dae" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/camera_link.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/camera_link.dae" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="camera_holder">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/camera_holder.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robo_ai/models/delivery_robot/meshes/camera_holder.dae" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.18 0.0 0.22" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="lidar"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.22 0.0 0.12" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="camera_link"/>
  </joint>

  <joint name="camera_holder_joint" type="fixed">
    <origin xyz="0.18 0.0 0.12" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="camera_holder"/>
  </joint>

</robot>
